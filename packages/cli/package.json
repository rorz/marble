{
  "name": "marble-cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "marble": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
