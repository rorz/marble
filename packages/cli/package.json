{
  "name": "marble-cli",
  "version": "0.0.3",
  "type": "module",
  "files": [
    "dist/cli.js"
  ],
  "bin": {
    "marble": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --target=node --outfile ./dist/cli.js",
    "dev": "bun build ./src/cli.ts --target=node --outfile ./dist/cli.js --watch",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/cli.js",
    "install:local": "bun link"
  },
  "devDependencies": {
    "@marble/core": "workspace:*",
    "@t3-oss/env-core": "catalog:base",
    "@types/node": "catalog:base",
    "commander": "catalog:base",
    "dotenv": "catalog:base",
    "typescript": "catalog:base",
    "zod": "catalog:base"
  }
}
