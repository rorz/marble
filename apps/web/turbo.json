{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "MARBLE_EXECUTOR_URL",
        "MARBLE_INGESTOR_URL",
        "NEXT_PUBLIC_MARBLE_WEB_SESSION_API_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env.local", "$TURBO_ROOT$/.env"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["$TURBO_EXTENDS$", "typegen"]
    },
    "typegen": {
      "outputs": [
        "next-env.d.ts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
      ]
    }
  }
}
