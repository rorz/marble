{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["tsconfig.json"],
  "tasks": {
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dangerously-splat": {
      "cache": false
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["^deploy"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "gen:seed": {
      "cache": false
    },
    "install:local": {
      "cache": false,
      "dependsOn": ["^install:local"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "symlink": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "cache": false,
      "dependsOn": ["^typecheck"]
    },
    "typegen": {
      "cache": false,
      "dependsOn": ["^typegen"]
    }
  }
}
