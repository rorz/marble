{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["tsconfig.json"],
  "globalEnv": [
    "EXECUTOR_URL",
    "INIT_CWD",
    "MARBLE_API_KEY",
    "MARBLE_API_URL",
    "MARBLE_EXECUTOR_URL",
    "MARBLE_INGESTOR_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_URL"
  ],
  "tasks": {
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "build": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["^deploy"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "install:local": {
      "cache": false,
      "dependsOn": ["^install:local"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "symlink": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "cache": false,
      "dependsOn": ["^typecheck"]
    },
    "typegen": {
      "cache": false,
      "dependsOn": ["^typegen"]
    }
  }
}
