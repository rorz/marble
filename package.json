{
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "knip": "^6.12.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "name": "marble",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "bun typegen && turbo run format-and-lint:fix && bun harness && bun typecheck && bun run build",
    "dangerously-splat": "turbo run dangerously-splat --",
    "dependency-graph": "dot -Tsvg dependency-graph.dot -o dependency-graph.svg",
    "deploy": "turbo run deploy",
    "dev": "turbo run dev",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "gen:seed": "turbo run gen:seed",
    "harness": "bun run harness/index.ts",
    "install:local": "turbo run install:local",
    "symlink": "turbo run symlink",
    "typecheck": "turbo run typecheck",
    "typegen": "turbo run typegen"
  },
  "workspaces": {
    "catalog": {},
    "catalogs": {
      "base": {
        "@cloudflare/sandbox": "^0.8.6",
        "@monaco-editor/react": "4.7.0",
        "@orpc/client": "^1.14.0",
        "@orpc/contract": "^1.14.0",
        "@orpc/openapi": "^1.14.0",
        "@orpc/server": "^1.14.0",
        "@orpc/zod": "^1.14.0",
        "@phosphor-icons/react": "^2.1.1",
        "@radix-ui/react-dialog": "^1.1.6",
        "@supabase/ssr": "^0.10.0",
        "@supabase/supabase-js": "^2",
        "@t3-oss/env-core": "^0.12.0",
        "@t3-oss/env-nextjs": "^0.12.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^22",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "ag-grid-community": "^35.2.0",
        "ag-grid-react": "^35.2.0",
        "ai": "^6.0.146",
        "babel-plugin-react-compiler": "1.0.0",
        "bun-types": "^1.3.11",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "cmdk": "^1.1.1",
        "commander": "^12",
        "dotenv": "^16",
        "hono": "^4",
        "jsonpath-plus": "10.4.0",
        "monaco-editor": "0.55.1",
        "nanoid": "^5.1.7",
        "next": "16.2.4",
        "prismjs": "^1.30.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-simple-code-editor": "^0.14.1",
        "server-only": "^0.0.1",
        "sift": "17.1.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "3.3.1",
        "tailwindcss": "^4",
        "typescript": "^5",
        "wrangler": "^4.85",
        "zod": "4.3.6"
      }
    },
    "packages": [
      "packages/*",
      "apps/*",
      "harness",
      "supabase",
      ".agents/skills/*"
    ]
  }
}
