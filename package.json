{
  "name": "marble",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "supabase"
    ],
    "catalogs": {
      "base": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "next": "16.2.1",
        "babel-plugin-react-compiler": "1.0.0",
        "tailwindcss": "^4",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^22",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@supabase/supabase-js": "^2",
        "supabase": "^2.84.0",
        "typescript": "^5",
        "hono": "^4",
        "@biomejs/biome": "2.2.0",
        "zod": "4.3.6",
        "sift": "17.1.3",
        "jsonpath-plus": "10.4.0",
        "vitest": "^4",
        "wrangler": "^4",
        "commander": "^12",
        "dotenv": "^16"
      }
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "typegen": "turbo run typegen",
    "check": "bun typegen && turbo run format-and-lint:fix && bun typecheck && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:base",
    "turbo": "^2.9.5"
  }
}
