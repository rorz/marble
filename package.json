{
  "name": "marble",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "supabase",
      ".agents/skills/*"
    ],
    "catalogs": {
      "base": {
        "@cloudflare/sandbox": "^0.8.6",
        "@heroicons/react": "^2.2.0",
        "@monaco-editor/react": "4.7.0",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "next": "16.2.1",
        "babel-plugin-react-compiler": "1.0.0",
        "tailwindcss": "^4",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^22",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@supabase/ssr": "^0.10.0",
        "@supabase/supabase-js": "^2",
        "ag-grid-community": "^35.2.0",
        "ag-grid-react": "^35.2.0",
        "supabase": "^2.84.0",
        "typescript": "^5",
        "hono": "^4",
        "@biomejs/biome": "^2",
        "@postgres-language-server/cli": "^0.23.0",
        "@t3-oss/env-core": "^0.12.0",
        "@t3-oss/env-nextjs": "^0.12.0",
        "zod": "4.3.6",
        "sift": "17.1.3",
        "jsonpath-plus": "10.4.0",
        "vitest": "^4",
        "wrangler": "^4",
        "commander": "^12",
        "dotenv": "^16",
        "nanoid": "^5.1.7",
        "monaco-editor": "0.55.1",
        "prismjs": "^1.30.0",
        "react-simple-code-editor": "^0.14.1",
        "tailwind-merge": "3.3.1"
      }
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "symlink": "turbo run symlink",
    "install:local": "turbo run install:local",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "typegen": "turbo run typegen",
    "check": "bun typegen && turbo run format-and-lint:fix && bun typecheck && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@postgres-language-server/cli": "^0.23.0",
    "turbo": "^2.9.5",
    "typescript": "^5.9.3"
  }
}
